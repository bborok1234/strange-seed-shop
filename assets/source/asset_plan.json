  "batch": {
    "id": "milestone1_style_validation_001",
    "purpose": "Validate Codex native image generation for the first static game asset batch before Phase 0 implementation. Sprite batch 001 extends the proof with six starter spritesheet/fx strips.",
    "target_asset_count": 26,
    "generation_mode": "codex_native_image_generation",
    "runtime_generation_allowed": false
  },
  "visual_bible": {
    "style": "Cute-strange greenhouse collectible game art for a browser-first idle game. Polished 2D illustration, soft rounded silhouettes, clean mobile readability, warm whimsical mood, slightly odd but friendly plant-creature forms.",
    "palette": [
      "fresh herb greens",
      "warm leaf yellow",
      "soft candy pink",
      "cream highlight",
      "moonlit blue",
      "silver lavender",
      "deep greenhouse teal accents"
    ],
    "composition_rules": [
      "Center the main subject with generous padding for UI cropping.",
      "Keep silhouettes readable at 96px.",
      "Use clean edges suitable for card and icon use.",
      "Avoid busy backgrounds for icons and creatures.",
      "Use family-specific visual motifs consistently: leaves for Herb, glossy sweets for Candy, crescent glow for Lunar."
    ],
    "avoid": [
      "copyrighted characters",
      "brand logos",
      "living artist style imitation",
      "horror or gore",
      "photorealistic insects",
      "watermarks",
      "unrequested text",
      "overly complex tiny details",
      "dark low-contrast silhouettes"
    ]
  },
